# Base URL of the backend API (docs/api_design.md). Never commit a real .env file.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# The site's own public URL — used for absolute Open Graph/Twitter card URLs
# and metadataBase (frontend/src/app/layout.tsx). Falls back to
# http://localhost:3000 if unset, so this is only required on a real
# deployment (docs/DEPLOYMENT.md) — without it, OG cards would carry a
# localhost URL in production.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Forward-compat flag for a future login/register UI (KI-039) — no login UI
# exists yet, so this currently has no effect. Leave "false" (the default)
# on any deployment without a shared custom domain between frontend and
# backend, since SameSite=Strict session cookies cannot work cross-site.
NEXT_PUBLIC_AUTH_ENABLED=false
