# Safe baseline: let Git detect text vs. binary and normalize line endings to
# LF in the repository for anything not explicitly overridden below.
* text=auto eol=lf

# --- Explicit LF (source code, must stay consistent across Windows, Linux,
#     Docker containers, GitHub Actions runners, and every future contributor) ---
*.py     text eol=lf
*.md     text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
Dockerfile text eol=lf
*.sh     text eol=lf

# --- Frontend (M7) — added when frontend/ was first scaffolded, resolving KI-010 ---
*.ts     text eol=lf
*.tsx    text eol=lf
*.js     text eol=lf
*.jsx    text eol=lf
*.mjs    text eol=lf
*.mts    text eol=lf
*.cjs    text eol=lf
*.json   text eol=lf
*.css    text eol=lf

# --- Explicit CRLF (Windows-only scripts) ---
*.bat text eol=crlf
*.ps1 text eol=crlf

# --- Explicit binary (never text-normalize or diff as text) ---
*.pdf  binary
*.docx binary
*.png  binary
*.jpg  binary
*.jpeg binary
*.ico  binary
