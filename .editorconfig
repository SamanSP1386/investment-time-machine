root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
insert_final_newline = true
trim_trailing_whitespace = true

# Markdown often uses a trailing double-space to force a line break —
# trimming it would silently break intentional formatting.
[*.md]
trim_trailing_whitespace = false

# Kept consistent with .gitattributes, which forces CRLF for these two
# extensions — without this override, editors would save LF locally per the
# [*] default above while Git normalizes to CRLF on checkout, causing
# constant whitespace-only diffs.
[*.{bat,ps1}]
end_of_line = crlf
