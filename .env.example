# Application
APP_NAME="Investment Time Machine"
ENVIRONMENT=development

# Database
DATABASE_URL=postgresql://itm_user:itm_password@localhost:5432/itm_dev

# Frontend origin(s) allowed to call the API
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Data Ingestion (Milestone 2) — FRED requires a free API key: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=
INGESTION_HTTP_TIMEOUT_SECONDS=10.0

# API Layer (Milestone 4) — rate limiting
REDIS_URL=redis://localhost:6379/0
RATE_LIMIT_SIMULATION_PER_MINUTE=60
RATE_LIMIT_READ_PER_MINUTE=100

# Reserved for future milestones — do not set until the relevant milestone introduces them
# JWT_SECRET=
# AI_PROVIDER_API_KEY=
