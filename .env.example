# Application
APP_NAME="Investment Time Machine"
ENVIRONMENT=development

# Database
# In any real deployment (ENVIRONMENT not one of development/test/testing),
# app.core.config.Settings refuses to start if this is still the local
# placeholder below — see docs/DEPLOYMENT.md.
DATABASE_URL=postgresql://itm_user:itm_password@localhost:5432/itm_dev

# Frontend origin(s) allowed to call the API. Accepts a comma-separated list
# (e.g. "http://localhost:3000,http://localhost:3001") — useful locally when
# Next.js drifts to a different port, and in production to list a Vercel
# domain plus its preview domains. Same production fail-fast guard as
# DATABASE_URL above applies if this is left at the localhost placeholder.
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Data Ingestion (Milestone 2) — FRED requires a free API key: https://fred.stlouisfed.org/docs/api/api_key.html
FRED_API_KEY=
INGESTION_HTTP_TIMEOUT_SECONDS=10.0

# API Layer (Milestone 4) — rate limiting
# REDIS_URL is OPTIONAL (ADR-047, Milestone 8): unset/empty means "no
# Redis" and the app falls back automatically to an in-process rate limiter
# and account lockout (app.core.rate_limit.InMemoryRateLimiter /
# app.auth.lockout.InMemoryAccountLockout) — logged clearly at startup.
# Local dev sets it (matching docker-compose.yml's redis service); a
# Redis-less deployment (e.g. Render free tier) should simply not set it.
REDIS_URL=redis://localhost:6379/0
RATE_LIMIT_SIMULATION_PER_MINUTE=60
RATE_LIMIT_READ_PER_MINUTE=100

# Identity Management (Milestone 5)
# JWT_SECRET must be a long, random, unguessable value in every real
# environment (staging/production) — never reuse the local placeholder.
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET=changeme-dev-only-do-not-use-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30
RATE_LIMIT_AUTH_PER_MINUTE=10
ACCOUNT_LOCKOUT_MAX_ATTEMPTS=5
ACCOUNT_LOCKOUT_WINDOW_MINUTES=15
# Must be true in staging/production (HTTPS). Only ever set to false for
# local, non-TLS development where the browser would otherwise silently
# refuse to store a Secure cookie.
COOKIE_SECURE=true

# Educational AI System (Milestone 6)
# AI_PROVIDER selects the adapter: "none" (default; NullProvider, no network
# calls, no key required — the platform is fully functional with AI
# unconfigured) or "anthropic". Setting AI_PROVIDER=anthropic with an empty
# AI_PROVIDER_API_KEY is a startup-time error (mirrors the JWT_SECRET guard).
AI_PROVIDER=none
AI_PROVIDER_API_KEY=
AI_MODEL_NAME=claude-3-5-haiku-20241022
AI_MAX_OUTPUT_TOKENS=800
AI_REQUEST_TIMEOUT_SECONDS=12.0
RATE_LIMIT_AI_PER_MINUTE=20
AI_MAX_EXPLANATION_REGENERATIONS=3
AI_MAX_FOLLOWUP_QUESTIONS=10
